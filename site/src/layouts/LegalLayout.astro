---
import BaseLayout from "@/layouts/BaseLayout.astro";
interface Props {
  title: string;
  description?: string;
  updated: string;
}
const { title, description, updated } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class="border-b border-navy/10 bg-tint">
    <div class="container-tb py-12 lg:py-16">
      <span class="eyebrow">Legal</span>
      <h1 class="mt-3 text-3xl sm:text-4xl">{title}</h1>
      <p class="mt-2 text-sm text-body">Last updated: {updated}</p>
    </div>
  </section>

  <!-- Lawyer-review banner: the structure is built in code; the binding
       legal WORDING is for the lawyer to review/complete (Spec Page 7). -->
  <div class="bg-amber/10">
    <div class="container-tb py-4">
      <p class="flex items-start gap-2 text-sm text-amber">
        <strong class="shrink-0">⚠ Pending legal review.</strong>
        <span class="text-navy/80"
          >This page's structure is in place. Passages marked
          <code class="rounded bg-white px-1.5 py-0.5 text-xs">[ FOR LAWYER REVIEW ]</code>
          are placeholders for our counsel to complete or approve before the
          app is submitted. No binding legal text has been invented.</span
        >
      </p>
    </div>
  </div>

  <section class="bg-white">
    <div
      class="container-tb max-w-3xl py-12 lg:py-16 [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-extrabold [&_h2]:text-navy [&_h3]:mt-6 [&_h3]:text-lg [&_h3]:font-bold [&_h3]:text-navy [&_p]:mt-3 [&_p]:leading-relaxed [&_p]:text-body [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:space-y-1.5 [&_ul]:pl-6 [&_ul]:text-body [&_a]:font-semibold [&_a]:text-blue [&_a]:underline"
    >
      <slot />
    </div>
  </section>
</BaseLayout>

<style>
  /* placeholder chips for lawyer-review passages */
  :global(.placeholder) {
    display: block;
    margin-top: 0.75rem;
    border-left: 3px solid var(--color-amber);
    background: #fff8f2;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    color: #8a3d00;
    font-size: 0.9rem;
  }
</style>
