---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import Icon from "@/components/Icon.astro";
import FinalCTA from "@/components/FinalCTA.astro";
import RexSessionDemo from "@/components/RexSessionDemo.astro";

// The five real stages of a Rex session (app-accurate).
const stages = [
  {
    icon: "compass",
    name: "Context Capture",
    body: "Rex opens by asking a few quick job questions in one message — job type, your state, system age, and the plumbing specifics (water supply, pipe material, system type). Every answer is tuned to your actual job.",
  },
  {
    icon: "camera",
    name: "Problem Identification",
    body: "Send a photo and describe it by voice. Rex assesses the photo, checks what it sees against what you said, and pinpoints the root cause — not just the symptom.",
  },
  {
    icon: "doc",
    name: "Diagnosis",
    body: "Rex gives you the full picture in order: what it is, the issue, the cause, the fix and alternatives, and the exact code rule with citation and the AHJ verify note. Then it confirms before moving on.",
  },
  {
    icon: "wrench",
    name: "Step-by-Step Guidance",
    body: "Rex walks the repair one step at a time. Send progress photos and it checks your work, flags any risk before you hit it, and gives the next step. You decide what to correct — Rex never blocks you.",
  },
  {
    icon: "check",
    name: "Completion",
    body: "Rex guides the final inspection and function test, then closes the job — and generates the professional report and quote on the spot.",
  },
];

const capabilities = [
  {
    icon: "compass",
    title: "Diagnosis help",
    body: "When the leak could be three things, Rex helps you rule them out fast — the most likely cause and the test to confirm it — so you stop guessing and start moving.",
  },
  {
    icon: "doc",
    title: "Code reference",
    body: "The right code section for the job you're standing on, in plain language, with the citation — and always the note to verify adoption with your AHJ. Certainty, not a hunch.",
  },
  {
    icon: "wrench",
    title: "Report & quote generation",
    body: "Turn the work into professional reports and quotes that win the job and let you charge what you're worth — consistent every time, across every tech.",
  },
];
---

<BaseLayout
  title="How It Works"
  description="See a real job, start to finish: a stuck moment, Rex, and a certain, code-backed answer that closes the job. Diagnosis help, code reference, reports & quotes — and Rex always informs your judgment, never replaces it."
>
  <!-- intro -->
  <section class="bg-gradient-to-b from-tint to-white">
    <div class="container-tb py-16 text-center lg:py-20">
      <span class="eyebrow">How it works</span>
      <h1 class="mx-auto mt-4 max-w-3xl text-4xl sm:text-5xl">
        A real job, start to finish.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-body sm:text-xl">
        No more standing there guessing. You're unstuck in seconds and back on
        the job — certain, moving, closing.
      </p>
    </div>
  </section>

  <!-- PART A — THE FIVE STAGES -->
  <Section tone="white">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">How a Rex session runs</span>
      <h2 class="mt-3 text-3xl sm:text-4xl">
        Five stages, from first question to closed job.
      </h2>
      <p class="mt-4 text-lg text-body">
        Every job runs through the same five stages — each one tuned to the
        work right in front of you.
      </p>
    </div>

    <ol class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        stages.map((s, i) => (
          <li class="relative flex flex-col rounded-[var(--radius-card)] bg-surface p-7 shadow-[var(--shadow-card)]">
            <div class="flex items-center gap-3">
              <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-navy text-white">
                <Icon name={s.icon as any} size={22} />
              </span>
              <span class="text-sm font-bold uppercase tracking-wide text-blue">
                Stage {i + 1}
              </span>
            </div>
            <h3 class="mt-4 text-xl text-navy">{s.name}</h3>
            <p class="mt-2 text-body">{s.body}</p>
          </li>
        ))
      }
    </ol>

    <!-- flexibility + always-on safety -->
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <div class="rounded-[var(--radius-card)] border border-navy/10 bg-white p-6">
        <div class="flex items-center gap-2 text-blue">
          <Icon name="compass" size={20} />
          <h3 class="text-lg text-navy">You set the pace</h3>
        </div>
        <p class="mt-2 text-body">
          At any stage you can skip ahead, ask a question, send more photos, or
          push back — and Rex adapts to where you actually are on the job.
        </p>
      </div>
      <div class="rounded-[var(--radius-card)] border-l-4 border-amber bg-surface p-6">
        <div class="flex items-center gap-2 text-amber">
          <Icon name="shield" size={20} />
          <h3 class="text-lg text-navy">Safety runs throughout</h3>
        </div>
        <p class="mt-2 text-body">
          The safety layer runs across every stage. A real hazard is flagged
          specifically, right when it matters — and you always have the final
          say.
        </p>
      </div>
    </div>
  </Section>

  <!-- PART B — THE CONCRETE DEMO -->
  <Section tone="navy">
    <div class="grid items-center gap-12 lg:grid-cols-[1fr_auto]">
      <div>
        <span class="eyebrow text-blue">One real job, start to finish</span>
        <h2 class="mt-3 text-3xl text-white sm:text-4xl">
          Watch Rex close a kitchen-sink drain leak.
        </h2>
        <p class="mt-5 max-w-xl text-lg text-white/80">
          A residential P-trap leak in Ohio — the same session a working
          plumber runs. Follow it through all five stages: Rex captures the
          context, reads the photo, diagnoses the failed slip-joint with the
          code rule, walks the fix step by step, and closes the job with a
          report and quote.
        </p>
        <ol class="mt-6 space-y-2.5">
          {
            stages.map((s, i) => (
              <li class="flex items-center gap-3 text-white/85">
                <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-white/10 text-sm font-bold text-blue">
                  {i + 1}
                </span>
                <span class="text-sm font-semibold">{s.name}</span>
              </li>
            ))
          }
        </ol>
      </div>
      <div class="flex justify-center lg:justify-end">
        <RexSessionDemo />
      </div>
    </div>
  </Section>

  <!-- 3 CAPABILITIES -->
  <Section tone="tint">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">What Rex does on the job</span>
      <h2 class="mt-3 text-3xl sm:text-4xl">Three ways Rex keeps you certain.</h2>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        capabilities.map((c) => (
          <div class="rounded-[var(--radius-card)] bg-white p-7 shadow-[var(--shadow-card)]">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-navy text-white">
              <Icon name={c.icon as any} />
            </span>
            <h3 class="mt-5 text-xl">{c.title}</h3>
            <p class="mt-2 text-body">{c.body}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- SAFETY AS TRUST -->
  <Section tone="white">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div class="rounded-[var(--radius-card)] border-l-4 border-amber bg-surface p-8">
        <span class="inline-flex items-center gap-2 rounded-full bg-amber/10 px-3 py-1 text-sm font-bold text-amber">
          <Icon name="shield" size={18} /> Rex has your back
        </span>
        <p class="mt-4 text-2xl font-extrabold leading-snug text-navy">
          On a real hazard — gas, CO, a fall risk, a live circuit — Rex stops
          you before anything else.
        </p>
      </div>
      <div>
        <h2 class="text-3xl sm:text-4xl">Safety first — always.</h2>
        <p class="mt-4 text-lg text-body">
          Before Rex answers anything, it checks for the dangerous stuff. If
          there's a real hazard in front of you, that comes first — every time.
        </p>
        <p class="mt-4 text-lg text-body">
          This isn't there to scare you. It's there because a master watching
          your back would do the same. It's how Rex earns your trust on the job.
        </p>
      </div>
    </div>
  </Section>

  <!-- IN CONTROL -->
  <Section tone="navy">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow text-blue">You stay the professional</span>
      <h2 class="mt-3 text-3xl text-white sm:text-4xl">
        Rex informs your judgment. It never replaces it.
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-white/80">
        You already know the trade. Rex is the certainty in your pocket — not
        the boss. It backs your call with a code-backed answer; the call, the
        licence, and the name on the work stay yours.
      </p>
    </div>
  </Section>

  <FinalCTA
    heading="See it on your next job."
    sub="Hit a wall, ask Rex, keep moving. Free to start — 10 questions on the house."
  />
</BaseLayout>
