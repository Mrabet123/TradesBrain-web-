---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import StoreBadges from "@/components/StoreBadges.astro";
import FinalCTA from "@/components/FinalCTA.astro";
import Icon from "@/components/Icon.astro";
import { PLANS, TRIAL } from "@/data/site";
---

<BaseLayout
  title="Plans"
  description="Solo, Pro, and Team. One job you don't lose to a stall covers the whole year. Start free with 10 questions, then keep moving."
>
  <!-- intro -->
  <section class="bg-gradient-to-b from-tint to-white">
    <div class="container-tb py-16 text-center lg:py-20">
      <span class="eyebrow">Plans</span>
      <h1 class="mx-auto mt-4 max-w-3xl text-4xl sm:text-5xl">
        Invest in the day back. Keep moving, close more, earn more.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-body sm:text-xl">
        Less than what one stalled afternoon costs you — and it's working every
        job, every day.
      </p>
    </div>
  </section>

  <!-- TRIAL -->
  <Section tone="white" class="!pb-0">
    <div class="mx-auto max-w-3xl rounded-[var(--radius-card)] border border-blue/30 bg-tint p-8 text-center">
      <span class="eyebrow">The low-risk start</span>
      <h2 class="mt-2 text-2xl sm:text-3xl">{TRIAL.headline}</h2>
      <p class="mx-auto mt-3 max-w-xl text-body">{TRIAL.line}</p>
    </div>
  </Section>

  <!-- PLANS -->
  <Section tone="white">
    <div class="grid items-stretch gap-6 lg:grid-cols-3">
      {
        PLANS.map((plan) => (
          <div
            class:list={[
              "relative flex flex-col rounded-[var(--radius-card)] border bg-white p-8 shadow-[var(--shadow-card)]",
              plan.anchored ? "border-blue ring-2 ring-blue/30 lg:-mt-4 lg:mb-0" : "border-navy/10",
            ]}
          >
            {plan.anchored && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-blue px-4 py-1 text-xs font-bold uppercase tracking-wide text-white">
                Most pros choose this
              </span>
            )}
            <h3 class="text-2xl">{plan.name}</h3>
            <p class="mt-1 min-h-[2.5rem] text-sm text-body">{plan.forWho}</p>
            <div class="mt-5">
              <span class="text-5xl font-extrabold tracking-tight text-navy">
                ${plan.annualMonthly}
              </span>
              <span class="text-body">/mo{"unit" in plan ? ` · ${plan.unit}` : ""}</span>
              <p class="mt-1 text-xs text-body/70">
                ${plan.annualTotal}/yr billed annually · or ${plan.monthly}/mo month-to-month
              </p>
              {"extraSeat" in plan && (
                <p class="mt-1 text-xs font-medium text-blue">{plan.extraSeat}</p>
              )}
            </div>
            <p class="mt-4 text-sm font-semibold text-navy">{plan.valueLine}</p>
            <ul class="mt-6 flex-1 space-y-3">
              {plan.features.map((f) => (
                <li class="flex gap-2.5 text-sm text-body">
                  <Icon name="check" size={18} class="mt-0.5 shrink-0 text-success" />
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <a
              href="/download"
              class:list={[
                "mt-7 inline-flex items-center justify-center rounded-xl px-6 py-3 text-base font-semibold transition hover:-translate-y-0.5",
                plan.anchored
                  ? "bg-blue text-white hover:bg-blue-600"
                  : "border-2 border-navy/15 text-navy hover:border-navy hover:bg-tint",
              ]}
            >
              Start free
            </a>
          </div>
        ))
      }
    </div>

    <!-- annual framing -->
    <div class="mx-auto mt-10 max-w-3xl rounded-[var(--radius-card)] bg-surface p-6 text-center">
      <p class="text-lg font-semibold text-navy">
        Annual is the smart, anchored choice.
      </p>
      <p class="mt-2 text-body">
        Lock the lower rate for the year and put the difference back in your
        pocket — value gained, working every job, every day.
      </p>
      <!--
        Annual availability transparency (TradesBrain_UnifiedPricing_v1.xlsx,
        Task 4 / Line 1). Honest cross-surface note: monthly prices are
        identical everywhere; Pro & Team annual are not on iOS IAP (the
        $999.99 Apple cap) but ARE reachable by US iOS users via web checkout.
        Use this exact wording — it is on-brand and approved.
      -->
      <p class="mt-4 text-sm text-body/80">
        Annual billing for Pro and Team is available on web and Android — and
        for iOS users in the US via web checkout.
      </p>
    </div>
  </Section>

  <!-- PAYMENT CONSISTENCY (honest, cross-surface) -->
  <Section tone="tint">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow">One plan, every device</span>
      <h2 class="mt-3 text-3xl">The same plan, however you start.</h2>
      <p class="mt-4 text-lg text-body">
        Whether you download on iPhone or Android, your plan and what's included
        are the same. Manage it right from the app — start, change, or cancel
        whenever you want. No surprises across your devices.
      </p>
      <!--
        ⚠️ PAYMENT CONSISTENCY (Spec Page 3 + Build Playbook Page 3):
        This copy must match the iOS IAP decision (iOS Build Guide Step 0).
        If iOS uses In-App Purchase vs an external link, confirm the wording
        above so web/Android (Stripe) and iOS tell ONE consistent story.
        Update before this page ships.
      -->
    </div>
  </Section>

  <!-- value anchor + CTA -->
  <Section tone="white">
    <div class="mx-auto max-w-3xl rounded-[var(--radius-card)] border border-navy/10 bg-gradient-to-b from-tint to-white p-8 text-center shadow-[var(--shadow-card)] sm:p-12">
      <p class="text-2xl font-extrabold leading-snug text-navy sm:text-3xl">
        One job you don't lose to a stall covers the whole year.
      </p>
      <p class="mx-auto mt-4 max-w-xl text-body">
        Start free. Put Rex on your next ten questions and see the difference on
        the job.
      </p>
      <div class="mt-8">
        <StoreBadges align="center" />
      </div>
    </div>
  </Section>

  <FinalCTA />
</BaseLayout>
