---
/** Stylised phone showing Rex in action — a real job-site exchange that
 *  ends on a certain, code-backed answer with the AHJ verify note. */
import LottiePlayer from "./react/LottiePlayer.tsx";
import Icon from "./Icon.astro";
---

<div class="relative mx-auto w-[280px] sm:w-[300px]">
  <!-- glow -->
  <div class="absolute -inset-6 -z-10 rounded-[3rem] bg-blue/20 blur-3xl" aria-hidden="true"></div>

  <div class="overflow-hidden rounded-[2.5rem] border-[10px] border-navy-900 bg-white shadow-[var(--shadow-lift)]">
    <!-- status bar -->
    <div class="flex items-center justify-between bg-navy px-5 py-3 text-white">
      <span class="text-xs font-semibold">9:41</span>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center gap-1.5 text-xs font-bold">
          <span class="h-1.5 w-1.5 rounded-full bg-success"></span> Rex
        </span>
      </div>
    </div>

    <div class="space-y-3 bg-tint px-4 py-5">
      <!-- user: photo + voice -->
      <div class="ml-auto max-w-[82%] rounded-2xl rounded-br-sm bg-navy px-3.5 py-2.5 text-white">
        <div class="mb-2 flex items-center gap-2 rounded-lg bg-white/10 px-2 py-1.5 text-xs">
          <Icon name="camera" size={16} /> Photo of the job
        </div>
        <p class="text-sm leading-snug">
          “What's the min clearance for this water heater T&amp;P discharge?”
        </p>
      </div>

      <!-- rex thinking -->
      <div class="flex items-center gap-2">
        <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-white shadow-sm">
          <LottiePlayer
            client:visible
            src="/assets/motion/Rex_Thinking_Loop.json"
            className="h-7 w-7"
            ariaLabel="Rex thinking"
          />
        </span>
        <span class="text-xs font-semibold text-body">Rex is checking the code…</span>
      </div>

      <!-- rex answer -->
      <div class="mr-auto max-w-[88%] rounded-2xl rounded-bl-sm bg-white px-3.5 py-3 shadow-sm">
        <p class="text-sm font-semibold leading-snug text-navy">
          Terminate the discharge no more than 6&quot; above the floor or
          approved receptor — and never threaded at the end.
        </p>
        <div class="mt-2 flex items-center gap-1.5 rounded-lg bg-tint px-2 py-1.5 text-[0.7rem] font-semibold text-blue">
          <Icon name="doc" size={14} /> IPC 504.6 · code-backed
        </div>
        <p class="mt-2 text-[0.7rem] leading-snug text-body/80">
          Verify adoption with your AHJ — local amendments can apply.
        </p>
      </div>
    </div>
  </div>
</div>
