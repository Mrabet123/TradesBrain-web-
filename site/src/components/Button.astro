---
/**
 * Link-styled button. Variants: primary (blue), navy, ghost (outline), white.
 */
interface Props {
  href: string;
  variant?: "primary" | "navy" | "ghost" | "white";
  size?: "md" | "lg";
  class?: string;
}
const {
  href,
  variant = "primary",
  size = "md",
  class: className = "",
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-xl font-semibold transition will-change-transform hover:-translate-y-0.5";
const sizes = {
  md: "px-5 py-2.5 text-sm",
  lg: "px-7 py-3.5 text-base",
};
const variants = {
  primary: "bg-blue text-white shadow-card hover:bg-blue-600",
  navy: "bg-navy text-white shadow-card hover:bg-navy-900",
  ghost: "border-2 border-navy/20 text-navy hover:border-navy hover:bg-tint",
  white: "bg-white text-navy shadow-card hover:bg-tint",
};
---

<a href={href} class={`${base} ${sizes[size]} ${variants[variant]} ${className}`}>
  <slot />
</a>
