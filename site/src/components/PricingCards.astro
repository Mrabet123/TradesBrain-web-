---
/**
 * PricingCards — the three plan cards with one Monthly/Annual toggle on top.
 *
 * Used IDENTICALLY on the Pricing page (/pricing) and the homepage Plans
 * section so both surfaces show the same result. The cards keep their
 * positions, structure, and layout — this only adds the toggle, the
 * accurate pricing, and the savings badge (the hero of the annual view).
 *
 * The toggle flips every card together (price, sub-note, savings badge)
 * client-side: it sets `data-billing` on the root and CSS swaps the
 * monthly/annual blocks. Pricing is the single source of truth in
 * src/data/site.ts (PLANS).
 *
 * CHECKOUT: "Start free" carries the chosen billing period
 * (?billing=monthly|annual) so the correct Stripe checkout / trial can be
 * started once price IDs are wired.
 *   ⚠️ TODO (Stripe): map ?billing + plan id → the Stripe Price ID and open
 *   Checkout. On the web BOTH monthly and annual check out via Stripe (no
 *   Apple cap). Price IDs are not in the repo yet — wire them before launch.
 */
import Icon from "@/components/Icon.astro";
import { PLANS } from "@/data/site";

interface Props {
  /** Which state the toggle starts in. Annual is the anchored choice. */
  defaultBilling?: "monthly" | "annual";
}
const { defaultBilling = "annual" } = Astro.props;
---

<div class="tb-pricing" data-rex-pricing data-billing={defaultBilling}>
  <!-- Monthly / Annual toggle (switches all three cards together) -->
  <div class="mb-10 flex justify-center">
    <div
      class="inline-flex items-center gap-1 rounded-full border border-navy/15 bg-white p-1 shadow-[var(--shadow-card)]"
      role="group"
      aria-label="Choose billing period"
    >
      <button
        type="button"
        data-bill-btn="monthly"
        aria-pressed={defaultBilling === "monthly"}
        class:list={[
          "tb-bill-btn rounded-full px-5 py-2 text-sm font-bold transition",
          defaultBilling === "monthly" ? "bg-navy text-white" : "text-navy",
        ]}
      >
        Monthly
      </button>
      <button
        type="button"
        data-bill-btn="annual"
        aria-pressed={defaultBilling === "annual"}
        class:list={[
          "tb-bill-btn inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-bold transition",
          defaultBilling === "annual" ? "bg-navy text-white" : "text-navy",
        ]}
      >
        Annual
        <span class="rounded-full bg-success/15 px-2 py-0.5 text-[0.65rem] font-extrabold uppercase tracking-wide text-success">
          Save up to 20%
        </span>
      </button>
    </div>
  </div>

  <div class="grid items-stretch gap-6 lg:grid-cols-3">
    {
      PLANS.map((plan) => (
        <div
          class:list={[
            "relative flex flex-col rounded-[var(--radius-card)] border bg-white p-8 shadow-[var(--shadow-card)]",
            plan.anchored
              ? "border-blue ring-2 ring-blue/30 lg:-mt-4 lg:mb-0"
              : "border-navy/10",
          ]}
        >
          {plan.anchored && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-blue px-4 py-1 text-xs font-bold uppercase tracking-wide text-white">
              Most pros choose this
            </span>
          )}

          <h3 class="text-2xl">{plan.name}</h3>
          <p class="mt-1 min-h-[2.5rem] text-sm text-body">{plan.forWho}</p>

          {/* toggle-responsive price block — reserve height so it never jumps */}
          <div class="mt-5 min-h-[8.75rem]">
            {/* MONTHLY */}
            <div class="tb-monthly-only">
              <p>
                <span class="text-5xl font-extrabold tracking-tight text-navy">
                  ${plan.monthlyPrice}
                </span>
                <span class="text-body">/mo{plan.priceSuffix}</span>
              </p>
              <p class="mt-2 text-xs text-body/70">{plan.monthlySub}</p>
            </div>

            {/* ANNUAL — savings badge is the hero */}
            <div class="tb-annual-only">
              <p>
                <span class="text-5xl font-extrabold tracking-tight text-navy">
                  ${plan.annualPrice}
                </span>
                <span class="text-body">/mo{plan.priceSuffix}</span>
              </p>
              <p class="mt-2 text-xs text-body/70">{plan.annualSub}</p>
              <span class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-blue px-3 py-1 text-xs font-extrabold uppercase tracking-wide text-white shadow-[var(--shadow-card)]">
                <Icon name="check" size={14} /> {plan.saveBadge}
              </span>
            </div>
          </div>

          <p class="mt-5 text-sm font-semibold text-navy">{plan.valueLine}</p>

          <ul class="mt-6 flex-1 space-y-3">
            {plan.features.map((f) => (
              <li class="flex gap-2.5 text-sm text-body">
                <Icon name="check" size={18} class="mt-0.5 shrink-0 text-success" />
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <a
            href={`/download?billing=${defaultBilling}`}
            data-cta
            class:list={[
              "mt-7 inline-flex items-center justify-center rounded-xl px-6 py-3 text-base font-semibold transition hover:-translate-y-0.5",
              plan.anchored
                ? "bg-blue text-white hover:bg-blue-600"
                : "border-2 border-navy/15 text-navy hover:border-navy hover:bg-tint",
            ]}
          >
            Start free
          </a>
        </div>
      ))
    }
  </div>
</div>

<style>
  /* The toggle just sets data-billing on the root; CSS swaps the blocks. */
  [data-billing="monthly"] .tb-annual-only {
    display: none;
  }
  [data-billing="annual"] .tb-monthly-only {
    display: none;
  }
</style>

<script>
  // Wire every pricing block on the page (homepage + pricing share this).
  document.querySelectorAll<HTMLElement>("[data-rex-pricing]").forEach((root) => {
    const btns = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-bill-btn]"),
    );
    const ctas = Array.from(root.querySelectorAll<HTMLAnchorElement>("[data-cta]"));

    const setBilling = (billing: string) => {
      root.setAttribute("data-billing", billing);
      btns.forEach((b) => {
        const active = b.dataset.billBtn === billing;
        b.setAttribute("aria-pressed", String(active));
        b.classList.toggle("bg-navy", active);
        b.classList.toggle("text-white", active);
        b.classList.toggle("text-navy", !active);
      });
      ctas.forEach((c) => {
        const url = new URL(c.getAttribute("href") || "/download", location.origin);
        url.searchParams.set("billing", billing);
        c.setAttribute("href", url.pathname + url.search);
      });
    };

    btns.forEach((b) =>
      b.addEventListener("click", () => setBilling(b.dataset.billBtn || "annual")),
    );
    setBilling(root.getAttribute("data-billing") || "annual");
  });
</script>
