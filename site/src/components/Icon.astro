---
/** Inline line-icon set (stroke = currentColor). Keep names stable. */
interface Props {
  name:
    | "camera"
    | "mic"
    | "check"
    | "clock"
    | "dollar"
    | "stuck"
    | "shield"
    | "users"
    | "wrench"
    | "doc"
    | "compass"
    | "bolt"
    | "user"
    | "book";
  size?: number;
  class?: string;
}
const { name, size = 28, class: className = "" } = Astro.props;
const paths: Record<string, string> = {
  camera:
    "M3 8.5A2.5 2.5 0 0 1 5.5 6h1.2l.9-1.5A1 1 0 0 1 8.5 4h7a1 1 0 0 1 .9.5L17.3 6h1.2A2.5 2.5 0 0 1 21 8.5v8A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5v-8Z|M12 9.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Z",
  mic: "M12 3a3 3 0 0 0-3 3v6a3 3 0 0 0 6 0V6a3 3 0 0 0-3-3Z|M5 11a7 7 0 0 0 14 0|M12 18v3",
  check: "M4 12.5l5 5L20 6.5",
  clock: "M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Z|M12 7.5V12l3 2",
  dollar: "M12 2v20|M16.5 6.5C16 5 14.3 4 12 4 9 4 7.5 5.6 7.5 7.5 7.5 12 17 10 17 15c0 2-1.8 4-5 4-2.5 0-4.3-1-5-2.5",
  stuck:
    "M7 11V8a5 5 0 0 1 10 0v3|M5 11h14v9H5z|M12 14.5v2.5",
  shield: "M12 3l7 3v5c0 5-3.5 8-7 10-3.5-2-7-5-7-10V6l7-3Z|M9 12l2 2 4-4",
  users:
    "M16 18v-1a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v1|M9 9a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z|M22 18v-1a4 4 0 0 0-3-3.8|M16 2.2A3.5 3.5 0 0 1 16 9",
  wrench:
    "M14.7 6.3a4 4 0 0 0-5.2 5.2l-6 6a1.5 1.5 0 0 0 2.1 2.1l6-6a4 4 0 0 0 5.2-5.2l-2.4 2.4-2.1-2.1 2.4-2.4Z",
  doc: "M6 2h8l4 4v16H6z|M14 2v4h4|M9 12h6|M9 16h6|M9 8h2",
  compass: "M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Z|M15.5 8.5l-2 5-5 2 2-5 5-2Z",
  bolt: "M13 2L4 14h7l-1 8 9-12h-7l1-8Z",
  user: "M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z|M4 21v-1a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v1",
  book: "M5 4h11a2 2 0 0 1 2 2v14H7a2 2 0 0 1-2-2V4Z|M5 18a2 2 0 0 0 2 2h11|M9 8h6",
};
const segs = paths[name].split("|");
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.9"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {segs.map((d) => <path d={d} />)}
</svg>
