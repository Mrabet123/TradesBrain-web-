# ===================================================================
# TradesBrain internal dashboard — LOCAL credentials
# -------------------------------------------------------------------
# 1. Copy this file to ".env.local"  (cp .env.local.example .env.local)
# 2. Fill in the values below.
# 3. NEVER commit .env.local. NEVER deploy this app. Run it locally only.
# ===================================================================

# --- Local access gate -------------------------------------------------------
# A simple password prompt so a passerby on a shared machine can't open the
# dashboard. This is a light guard, not real auth — the real protection is that
# the app only ever runs on your own machine.
APP_PASSWORD=change-me-to-a-shared-team-password

# --- Supabase (READ access to the signup tables) -----------------------------
# Project URL — Supabase dashboard → Project Settings → Data API → Project URL
SUPABASE_URL=https://....supabase.co

# service_role key — Supabase dashboard → Project Settings → API → service_role.
# This key bypasses Row Level Security so the dashboard can read the PII tables.
# It is used ONLY on the server (never sent to the browser). Treat it like a
# password: do not share, do not commit, do not paste anywhere public.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Demo mode ---------------------------------------------------------------
# Set to 1 to ignore Supabase and show built-in sample rows (useful for a first
# look without credentials). Leave unset / 0 to read real data.
DASHBOARD_DEMO=0
